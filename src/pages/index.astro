---
import Layout from '../layouts/Layout.astro';

const stats = [
    { label: "Innovation Lab", val: "A.I." },
    { label: "User Base", val: "Global" },
    { label: "Core Focus", val: "Software" }
];
---

<Layout title="BasiXa | Building the Future of Software">
	<main>
		<!-- HERO SECTION -->
		<section class="relative pt-48 pb-32 px-6 overflow-hidden">
			<div class="max-w-7xl mx-auto relative z-10 text-center md:text-left">
				<div class="inline-block px-4 py-1.5 mb-8 rounded-full border border-purple-500/30 bg-purple-500/5 text-purple-400 text-xs font-bold uppercase tracking-widest animate-pulse">
					Next Generation Computing Lab
				</div>
				<h1 class="text-6xl md:text-[100px] font-extrabold tracking-tighter leading-[0.85] mb-12">
					Intelligence <br /> <span class="bg-gradient-to-r from-purple-400 via-pink-500 to-blue-400 bg-clip-text text-transparent">without limits.</span>
				</h1>
				<div class="flex flex-col md:flex-row gap-12 items-center">
					<p class="text-xl text-gray-400 max-w-xl leading-relaxed font-light">
						BasiXa is an independent technology house developing high-performance AI agents, creative suites, and experimental operating systems.
					</p>
					<div class="flex gap-12 border-l border-white/10 pl-12">
						{stats.map(s => (
							<div>
								<p class="text-3xl font-bold">{s.val}</p>
								<p class="text-gray-500 text-xs uppercase tracking-widest">{s.label}</p>
							</div>
						))}
					</div>
				</div>
			</div>
            <!-- Hero Image Background -->
            <div class="mt-20 max-w-7xl mx-auto rounded-[40px] overflow-hidden border border-white/10 relative group">
                <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent z-10"></div>
                <img src="https://images.unsplash.com/photo-1620641788421-7a1c342ea42e?q=80&w=2000" alt="Tech" class="w-full h-[600px] object-cover group-hover:scale-105 transition duration-1000" />
            </div>
		</section>

		<!-- PRODUCT DEEP-DIVE -->
		<section id="products" class="py-32 px-6 max-w-7xl mx-auto">
			<div class="mb-24">
				<h2 class="text-sm font-bold text-purple-500 uppercase tracking-[0.3em] mb-4">The Ecosystem</h2>
				<h3 class="text-5xl font-bold tracking-tight">Our Core Research.</h3>
			</div>

			<div class="grid gap-24">
				<!-- EasyAIAgents -->
				<div class="flex flex-col md:flex-row gap-20 items-center border-b border-white/5 pb-24">
					<div class="md:w-1/2">
						<h4 class="text-4xl font-bold mb-6">EasyAIAgents</h4>
						<p class="text-gray-400 text-lg leading-relaxed mb-8">
							Deploy autonomous reasoning engines that go beyond chat. Our agents handle live API integration, multi-step problem solving, and complex business logic with zero human intervention.
						</p>
						<a href="/products" class="text-purple-400 font-bold hover:underline">Explore Technology →</a>
					</div>
					<div class="md:w-1/2 rounded-3xl overflow-hidden shadow-2xl shadow-purple-500/10 border border-white/10">
						<img src="https://images.unsplash.com/photo-1677442136019-21780ecad995?q=80&w=1200" alt="AI" class="w-full h-80 object-cover" />
					</div>
				</div>

				<!-- Lumina -->
				<div class="flex flex-col md:flex-row-reverse gap-20 items-center border-b border-white/5 pb-24">
					<div class="md:w-1/2">
						<h4 class="text-4xl font-bold mb-6">Lumina Suite</h4>
						<p class="text-gray-400 text-lg leading-relaxed mb-8">
							A modern Android video engine. We rebuilt the mobile editing stack from scratch to allow professional-grade synthesis on portable devices.
						</p>
						<a href="/products" class="text-blue-400 font-bold hover:underline">See Features →</a>
					</div>
					<div class="md:w-1/2 rounded-3xl overflow-hidden shadow-2xl shadow-blue-500/10 border border-white/10">
						<img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=1200" alt="Video" class="w-full h-80 object-cover" />
					</div>
				</div>
			</div>
		</section>

		<!-- VISION & VALUES (Heavy Section) -->
		<section class="py-32 bg-white/5 border-y border-white/5">
			<div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-20">
				<div>
					<h2 class="text-4xl font-bold mb-12">Building for the <br /> <span class="text-gray-500 italic">Open Innovation.</span></h2>
					<div class="space-y-8">
						{['Intelligent Design', 'Speed as a Feature', 'Infinite Creativity', 'Global Accessibility'].map(v => (
							<div class="flex items-center gap-6 p-6 rounded-2xl bg-black border border-white/5">
								<div class="w-2 h-2 rounded-full bg-purple-500"></div>
								<p class="text-lg font-bold">{v}</p>
							</div>
						))}
					</div>
				</div>
				<div class="relative group">
                    <img src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=1200" class="rounded-[40px] border border-white/10 opacity-50 grayscale group-hover:grayscale-0 transition duration-700 h-full object-cover" />
                    <div class="absolute inset-0 flex items-center justify-center">
                        <div class="p-12 glass rounded-3xl text-center max-w-xs">
                            <p class="text-2xl font-bold italic">"Software should be as intuitive as thought."</p>
                        </div>
                    </div>
                </div>
			</div>
		</section>

		<!-- CEO / FOUNDER SECTION -->
		<section class="py-40 px-6 max-w-7xl mx-auto">
			<div class="flex flex-col md:flex-row gap-20 items-center">
				<div class="w-64 h-64 rounded-full overflow-hidden border-4 border-purple-500/20 shadow-2xl">
					<img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=600" alt="Abdul Basit HS" class="w-full h-full object-cover grayscale" />
				</div>
				<div class="max-w-2xl">
					<p class="text-purple-400 font-bold uppercase tracking-widest text-xs mb-4">Founder & CEO</p>
					<h2 class="text-5xl font-bold mb-8 tracking-tighter">Abdul Basit HS</h2>
					<p class="text-2xl text-gray-400 leading-relaxed font-light mb-12">
						"At BasiXa, we don't just build apps. We build the architecture for a future where technology amplifies human intent, not replaces it."
					</p>
					<div class="flex gap-8">
						<a href="https://x.com/basixa" class="text-sm font-bold underline">Twitter</a>
						<a href="https://linkedin.com/company/basixa" class="text-sm font-bold underline">LinkedIn</a>
					</div>
				</div>
			</div>
		</section>

        <!-- CTA SECTION -->
        <section class="py-32 px-6 text-center border-t border-white/5">
            <h2 class="text-4xl md:text-6xl font-bold mb-12 tracking-tighter">Ready to build the future?</h2>
            <a href="mailto:basixaofficial@gmail.com" class="px-12 py-5 bg-white text-black rounded-full font-black text-xl hover:bg-purple-500 hover:text-white transition duration-500 inline-block">
                Connect with BasiXa
            </a>
        </section>
	</main>

    <!-- FOOTER -->
    <footer class="py-20 px-6 border-t border-white/5 bg-[#010101]">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12">
            <div>
                <p class="text-2xl font-black mb-4">BASIXA</p>
                <p class="text-gray-500 text-sm max-w-xs leading-relaxed">Building powerful, accessible, and intelligent technology for the next generation.</p>
            </div>
            <div class="grid grid-cols-2 gap-20">
                <div>
                    <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-6">Pages</p>
                    <ul class="space-y-4 text-sm">
                        <li><a href="/" class="hover:text-purple-400">Home</a></li>
                        <li><a href="/products" class="hover:text-purple-400">Products</a></li>
                        <li><a href="/about" class="hover:text-purple-400">About</a></li>
                    </ul>
                </div>
                <div>
                    <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-6">Socials</p>
                    <ul class="space-y-4 text-sm">
                        <li><a href="https://x.com/basixa" class="hover:text-purple-400">@basixa</a></li>
                        <li><a href="https://github.com/basixa" class="hover:text-purple-400">GitHub</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="max-w-7xl mx-auto pt-20 text-center text-gray-600 text-[10px] uppercase tracking-[0.4em]">
            © 2024 BASIXA LABS — ALL RIGHTS RESERVED
        </div>
    </footer>
</Layout>

<style>
	.glass {
		background: rgba(255, 255, 255, 0.03);
		backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.05);
	}
</style>
