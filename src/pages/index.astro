---
import Layout from '../layouts/Layout.astro';

const products = [
  { name: "EasyAIAgents", role: "AI Automation", desc: "AI agents for business.", gradient: "from-purple-500 to-blue-500" },
  { name: "Lumina", role: "Video Editor", desc: "Next-gen video suite.", gradient: "from-orange-400 to-rose-500" },
  { name: "Max OS", role: "Operating System", desc: "Performance redefined.", gradient: "from-emerald-400 to-cyan-500" }
];

const socials = [
  { name: 'Twitter', url: 'https://x.com/basixa', icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' }
];
---

<Layout title="BasiXa | Future of Software">
	<main class="pt-32 pb-20 px-6 max-w-7xl mx-auto text-white">
		<h1 class="text-6xl font-black mb-8">Building the <span class="text-purple-500">Future</span>.</h1>
		<div class="grid md:grid-cols-3 gap-8">
			{products.map((p) => (
				<div class="p-8 rounded-3xl border border-white/10 bg-white/5">
					<div class={`w-10 h-10 rounded bg-gradient-to-br ${p.gradient} mb-4`}></div>
					<h3 class="text-2xl font-bold">{p.name}</h3>
					<p class="text-gray-400">{p.desc}</p>
				</div>
			))}
		</div>
	</main>
</Layout>
