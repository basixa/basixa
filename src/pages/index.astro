---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    name: "EasyAIAgents",
    tagline: "Autonomous Logic Engines",
    desc: "Next-gen AI agents designed for complex reasoning and workflow automation. Built for enterprise scale.",
    img: "https://images.unsplash.com/photo-1677442136019-21780ecad995?q=80&w=1200"
  },
  {
    name: "Lumina",
    tagline: "Professional Video Engine",
    desc: "A high-performance video suite for Android. Re-engineering the mobile creative stack with low-latency synthesis.",
    img: "https://images.unsplash.com/photo-1536240478700-b86734914a31?q=80&w=1200"
  },
  {
    name: "Max OS",
    tagline: "Performance Computing",
    desc: "An experimental OS built for extreme efficiency and native AI compatibility. Computing redefined.",
    img: "https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=1200"
  }
];

const socials = [
  { name: 'X.COM', url: 'https://x.com/basixa' },
  { name: 'GITHUB', url: 'https://github.com/basixa' },
  { name: 'INSTAGRAM', url: 'https://instagram.com/basixa' }
];
---

<Layout title="BasiXa | Building the Future of Software">
	<!-- Navbar -->
	<nav class="fixed top-0 w-full z-50 border-b border-white/5 bg-black/40 backdrop-blur-xl">
		<div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
			<div class="text-xl font-bold tracking-tighter uppercase">BasiXa</div>
			<div class="flex gap-8 items-center text-[10px] font-bold uppercase tracking-[0.2em] text-neutral-400">
				<a href="#products" class="hover:text-white transition">Products</a>
				<a href="#ceo" class="hover:text-white transition">Leadership</a>
				<a href="mailto:basixaofficial@gmail.com" class="text-white border border-white/20 px-4 py-2 rounded-full hover:bg-white hover:text-black transition duration-500">Contact</a>
			</div>
		</div>
	</nav>

	<main>
		<!-- Hero -->
		<section class="pt-48 pb-32 px-6 max-w-7xl mx-auto text-center md:text-left">
			<div class="max-w-4xl">
				<h1 class="text-6xl md:text-8xl font-bold tracking-tighter leading-[0.95] mb-12">
					Building the next generation of <span class="text-neutral-500 italic">intelligent systems.</span>
				</h1>
				<p class="text-xl md:text-2xl text-neutral-400 leading-relaxed max-w-2xl font-light">
					BasiXa is an independent software lab developing high-performance AI tools and experimental platforms for the creative age.
				</p>
			</div>
		</section>

		<!-- Products Section -->
		<section id="products" class="py-32 px-6 max-w-7xl mx-auto border-t border-white/5">
			<div class="grid gap-40">
				{products.map((p, index) => (
					<div class={`flex flex-col md:flex-row items-center gap-20 ${index % 2 !== 0 ? 'md:flex-row-reverse' : ''}`}>
						<div class="md:w-1/2">
							<h3 class="text-4xl md:text-5xl font-bold mb-6 tracking-tight leading-tight">{p.name}</h3>
							<p class="text-indigo-400 font-bold uppercase tracking-widest text-[10px] mb-4">{p.tagline}</p>
							<p class="text-neutral-400 text-lg leading-relaxed mb-8">{p.desc}</p>
							<div class="h-[1px] w-24 bg-white/10"></div>
						</div>
						<div class="md:w-1/2 rounded-[40px] overflow-hidden border border-white/10 group bg-neutral-900 shadow-2xl">
							<img src={p.img} alt={p.name} class="w-full h-[450px] object-cover group-hover:scale-105 transition duration-1000" />
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- CEO Section -->
		<section id="ceo" class="py-40 px-6 max-w-7xl mx-auto border-t border-white/5">
			<div class="flex flex-col md:flex-row items-center gap-24">
				<div class="md:w-1/3">
					<div class="rounded-[40px] overflow-hidden border border-white/10 shadow-2xl rotate-1 hover:rotate-0 transition duration-700">
						<!-- Image Path: public/ceo.jpg -->
						<img src="/ceo.jpg" alt="Abdul Basit HS" class="w-full aspect-[4/5] object-cover" />
					</div>
				</div>
				<div class="md:w-2/3">
					<span class="text-[10px] font-bold text-neutral-500 uppercase tracking-[0.3em] mb-6 block">Founder & CEO</span>
					<h2 class="text-6xl font-bold tracking-tighter mb-8">Abdul Basit HS</h2>
					<p class="text-2xl text-neutral-300 leading-relaxed font-light italic mb-10">
						"At BasiXa, we are committed to building technology that simplifies complexity and empowers human innovation at a global scale."
					</p>
					<div class="flex gap-12 pt-10 border-t border-white/5">
						<div>
							<p class="text-xs font-bold uppercase tracking-widest text-indigo-400">Leadership</p>
							<p class="text-[10px] text-neutral-600 uppercase tracking-widest mt-1">BasiXa Technologies</p>
						</div>
						<div class="flex gap-6">
							<a href="https://x.com/basixa" target="_blank" class="text-[10px] font-bold border border-white/10 px-6 py-2 rounded-full hover:bg-white hover:text-black transition">TWITTER</a>
							<a href="https://github.com/basixa" target="_blank" class="text-[10px] font-bold border border-white/10 px-6 py-2 rounded-full hover:bg-white hover:text-black transition">GITHUB</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Call to Action -->
		<section class="py-40 text-center px-6">
			<h2 class="text-5xl md:text-8xl font-bold tracking-tighter mb-16 opacity-20 hover:opacity-100 transition duration-1000">Innovate. Create. Build.</h2>
			<a href="mailto:basixaofficial@gmail.com" class="px-16 py-6 bg-white text-black rounded-full font-black text-sm uppercase tracking-widest hover:bg-indigo-600 hover:text-white transition duration-500">
				Get in touch
			</a>
		</section>
	</main>

	<!-- Best Version Footer -->
	<footer class="py-20 border-t border-white/5 px-6 bg-[#030303]">
		<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
			<div class="text-[10px] font-bold uppercase tracking-[0.4em] text-neutral-600">
				© 2026 BASIXA LABS — ALL RIGHTS RESERVED
			</div>
			<div class="flex gap-12 text-[10px] font-bold uppercase tracking-[0.3em] text-neutral-500">
				{socials.map(s => (
					<a href={s.url} target="_blank" class="hover:text-white transition">{s.name}</a>
				))}
			</div>
		</div>
	</footer>
</Layout>
