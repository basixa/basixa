---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    name: "EasyAIAgents",
    role: "Automation & Intelligence",
    desc: "Deploy autonomous AI agents that handle business logic, content creation, and developer workflows with zero friction.",
    gradient: "from-purple-500 to-blue-500"
  },
  {
    name: "Lumina",
    role: "Android Video Editor",
    desc: "A professional-grade mobile suite designed for the next generation of creators. Fast, intuitive, and extremely powerful.",
    gradient: "from-orange-400 to-rose-500"
  },
  {
    name: "Max OS",
    role: "Next-Gen Computing",
    desc: "Redefining the operating system. Built for performance and compatibility, designed for the future of application ecosystems.",
    gradient: "from-emerald-400 to-cyan-500"
  }
];

const socials = [
  { name: 'Twitter', url: 'https://x.com/basixa', icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
  { name: 'GitHub', url: 'https://github.com/basixa', icon: 'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12' },
];
---

<Layout title="BasiXa | Building the Future of Software">
	<nav class="fixed top-0 w-full z-50 border-b border-white/5 bg-black/50 backdrop-blur-md">
		<div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
			<div class="text-2xl font-black tracking-tighter uppercase">BasiXa</div>
			<div class="flex gap-8 items-center">
				<a href="#products" class="text-sm text-gray-400 hover:text-white transition">Products</a>
				<a href="mailto:basixaofficial@gmail.com" class="px-5 py-2 bg-white text-black text-sm font-bold rounded-full hover:bg-gray-200 transition">Contact</a>
			</div>
		</div>
	</nav>

	<main class="pt-32 pb-20 px-6 max-w-7xl mx-auto">
		<header class="text-center py-20">
			<h1 class="text-6xl md:text-8xl font-black tracking-tighter mb-8 leading-[0.9] bg-gradient-to-r from-white to-purple-400 bg-clip-text text-transparent">
				Building the <br/> Future of Software.
			</h1>
			<p class="text-xl text-gray-400 max-w-2xl mx-auto mb-12">
				BasiXa develops innovative products designed to empower creators, developers, and businesses.
			</p>
		</header>

		<section id="products" class="grid md:grid-cols-3 gap-8 py-20">
			{products.map(p => (
				<div class="p-8 rounded-3xl border border-white/10 bg-white/5 group hover:border-purple-500/50 transition-all">
					<div class={`w-12 h-12 rounded-lg bg-gradient-to-br ${p.gradient} mb-6`}></div>
					<h3 class="text-2xl font-bold mb-2">{p.name}</h3>
					<p class="text-xs font-bold text-purple-400 uppercase tracking-widest mb-4">{p.role}</p>
					<p class="text-gray-400 text-sm leading-relaxed">{p.desc}</p>
				</div>
			))}
		</section>
	</main>
</Layout>
