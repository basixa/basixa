---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>B</text></svg>" />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-[#030303] text-[#f5f5f5] font-['Inter'] antialiased">
		<!-- Global Glow Effects -->
		<div class="fixed top-0 left-1/4 w-[500px] h-[500px] bg-purple-600/10 blur-[120px] rounded-full -z-10"></div>
		<div class="fixed bottom-0 right-1/4 w-[600px] h-[600px] bg-blue-600/10 blur-[150px] rounded-full -z-10"></div>

		<nav class="fixed top-0 w-full z-50 border-b border-white/5 bg-black/60 backdrop-blur-xl">
			<div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
				<a href="/" class="text-xl font-bold tracking-tighter">BASIXA</a>
				<div class="flex gap-8 text-sm font-medium">
					<a href="/" class="hover:text-purple-400 transition">Home</a>
					<a href="/products" class="hover:text-purple-400 transition">Products</a>
					<a href="/about" class="hover:text-purple-400 transition">About</a>
					<a href="mailto:basixaofficial@gmail.com" class="bg-white text-black px-4 py-1.5 rounded-full hover:bg-purple-500 hover:text-white transition">Contact</a>
				</div>
			</div>
		</nav>

		<slot />

		<footer class="py-20 border-t border-white/5 bg-[#050505]">
			<div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8">
				<p class="text-gray-500 text-sm">© 2024 BasiXa. Building the Future.</p>
				<div class="flex gap-6">
					<a href="https://x.com/basixa" class="text-gray-400 hover:text-white transition">Twitter</a>
					<a href="https://github.com/basixa" class="text-gray-400 hover:text-white transition">GitHub</a>
				</div>
			</div>
		</footer>
	</body>
</html>
