---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const {
  title = "BasiXa — Building the Future of Software",
  description = "BasiXa is an independent technology company building AI agents, creative tools, and next-generation computing platforms. Founded by Abdul Basit HS.",
  image = "https://basixa.github.io/og-image.png",
  canonical = "https://basixa.github.io",
} = Astro.props;

const fullTitle = title.includes("BasiXa") ? title : `${title} — BasiXa`;
---
<!doctype html>
<html lang="en" data-theme="light">
  <head>
<meta name="google-site-verification" content="2uUBqxyUbpa9ynYxB2gWfLGI2mrSo5Cs0NBIz208Evo" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Abdul Basit HS" />
    <meta name="keywords" content="BasiXa, AI agents, EasyAIAgents, Lumina video editor, Max OS, Abdul Basit HS, technology company, software" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="BasiXa" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@basixa" />
    <meta name="twitter:creator" content="@basixa" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='white'/><text x='16' y='22' font-size='18' text-anchor='middle' font-family='Georgia,serif' fill='%23111'>B</text></svg>" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "BasiXa",
      "url": "https://basixa.github.io",
      "logo": "https://basixa.github.io/ceo.jpg",
      "description": "Independent technology company building AI agents, creative tools, and next-generation computing platforms.",
      "email": "basixaofficial@gmail.com",
      "founder": {
        "@type": "Person",
        "name": "Abdul Basit HS",
        "jobTitle": "Founder & CEO"
      },
      "sameAs": [
        "https://x.com/basixa",
        "https://github.com/basixa",
        "https://instagram.com/basixa"
      ]
    }
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #ffffff;
        --bg2: #f7f7f5;
        --surface: #f0efe9;
        --border: #e5e4df;
        --text: #1a1917;
        --text2: #6b6a65;
        --text3: #9b9a95;
        --accent: #c96a2e;
        --accent-hover: #a8551f;
        --radius: 12px;
        --radius-lg: 20px;
      }

      [data-theme="dark"] {
        --bg: #111110;
        --bg2: #191918;
        --surface: #222220;
        --border: #2e2e2c;
        --text: #f0efe9;
        --text2: #9b9a95;
        --text3: #6b6a65;
        --accent: #d4784a;
        --accent-hover: #e8894f;
      }

      html { scroll-behavior: smooth; font-size: 16px; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        font-weight: 400;
        line-height: 1.6;
        transition: background 0.3s, color 0.3s;
        -webkit-font-smoothing: antialiased;
      }

      ::selection { background: var(--accent); color: #fff; }
      a { color: inherit; text-decoration: none; }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }
    </style>
  </head>
  <body>
    <slot />
    <script is:inline>
      const saved = localStorage.getItem('theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
    </script>
  </body>
</html>
